# Backend URL the dev server proxies /api requests to (dev only).
# Copy this file to .env.local and adjust as needed.
VITE_API_PROXY_TARGET=http://localhost:4000

# Backend base URL baked into the production build (leave empty if the
# frontend and backend are served from the same domain in production).
# e.g. VITE_API_BASE_URL=https://expense-tracker-pennywise-backend1.onrender.com
VITE_API_BASE_URL=

# reCAPTCHA v2 site key (public). Get this from
# https://www.google.com/recaptcha/admin — pair it with RECAPTCHA_SECRET_KEY
# on the backend.
VITE_RECAPTCHA_SITE_KEY=
