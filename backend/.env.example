# Copy this file to .env and fill in values for local dev.

# Port the API listens on.
PORT=4000

# Set to "production" on Render so cookies get Secure + SameSite=None
# (required for cross-domain cookies between separate frontend/backend hosts).
# Leave unset (or "development") for local dev.
NODE_ENV=development

# Origin allowed to make credentialed requests (CORS). Must be an exact
# origin, not a wildcard, since credentials: true is set.
# Dev: http://localhost:5173
# Prod: e.g. https://expense-tracker-pennywise-frontend1.onrender.com
FRONTEND_URL=http://localhost:5173

# Postgres connection string.
# Local dev (Docker): postgresql://postgres:devpassword@localhost:5432/pennywise
# Render: use the "Internal Database URL" from your Render Postgres instance.
DATABASE_URL=

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=

# Whichever account signs up (or already exists) with this email gets
# auto-promoted to the "admin" role, giving access to /admin.
ADMIN_EMAIL=

# reCAPTCHA v2 secret key (server-side verification). Get this from
# https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
